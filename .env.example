# Google Gemini LLM API Key (Required for AI summarization)
# Obtain free key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Resend HTTPS API Key (Recommended for Cloud Hosts like Render where SMTP ports 465/587 are blocked)
# Obtain free key (3,000 emails/month free) from: https://resend.com
RESEND_API_KEY=

# Gmail SMTP Delivery Credentials (Used for local execution or fallback)
# Obtain 16-char App Password from: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
RECIPIENT_EMAIL=

# GitHub Personal Access Token (Optional: increases rate limit from 60/hr to 5,000/hr)
# Obtain token from: https://github.com/settings/tokens
GITHUB_TOKEN=

# Operational Defaults (Optional)
LOOKBACK_HOURS=24
TIMEZONE=Asia/Kolkata
